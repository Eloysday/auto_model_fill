# ── LLM API ────────────────────────────────────────────
KEY=your_api_key
BASE_URL=https://api.deepseek.com/v1
PRO_MODEL=deepseek-chat

# ── 并发控制（2 核 / 4 GB 服务器优化）─────────────────
MAX_CONCURRENT_JOBS=2       # 同时运行的 worker 数（匹配 CPU 核数）
MAX_QUEUE_DEPTH=6           # 最大排队任务数（超限返回 503）
JOB_TIMEOUT=600             # 单个任务超时秒数（10 分钟）
SHUTDOWN_GRACE_SECONDS=30   # 关闭时等待子进程的宽限秒数
